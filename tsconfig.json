{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    // "rootDir": "./src",
    // "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "esnext",  //nodenext
    "target": "esnext",
    "types": ["@playwright/test", "node"],    // empty [] IMPORTANT: added
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,    // changed it to false.

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "moduleResolution": "bundler",   //  IMPORTANT, added.
  },

  "include": ["tests/**/*.ts", "playwright.config.ts", "tests/zignore"]  // IMPORTANT, added.  
}


/* 
    * "include" setting specifies exactly which files and directories should be part of your TypeScript project's scope for type checking and IntelliSense
    *  playwright.config.ts: This explicitly includes your main Playwright configuration file in the project's type-checking context. 
    *  Including this file is crucial because it allows VS Code to provide autocompletion and error reporting for your global test settings
*/